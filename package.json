    "@testing-library/react": "16.3.2",
    "@types/lodash.merge": "4.6.9",
    "@types/lodash.throttle": "4.1.9",
    "@types/mdx": "2.0.13",
    "@types/node": "24.12.4",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "copy-webpack-plugin": "14.0.0",
